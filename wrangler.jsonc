{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ttx-operator-shell",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-30",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "vars": {
    "ENGINE_API_URL": "https://msh-ops-os-harness.sogellagepul.workers.dev",
    // Display-only identity labels rolled into the auth token — never
    // enforced against anything (no RBAC, per scope lock). Secrets
    // (OPERATOR_CALLSIGN, OPERATOR_PASSWORD_HASH, AUTH_SIGNING_KEY) are NOT
    // set here: use `wrangler secret put` for deploys, .dev.vars locally.
    "OPERATOR_ROLE": "operator",
    "OPERATOR_ACCESS_LEVEL": "internal",
    // Phase 17: /api/engine/health and /api/engine/version read these.
    // APP_VERSION is a manual mirror of package.json's "version" field —
    // bump both together, no build-step sync exists for this.
    "DEPLOY_ENV": "production",
    "APP_VERSION": "0.1.0",
    "BUILD_COMMIT_SHA": "unknown",
    "BUILD_TIMESTAMP": "",
    "SYSTEM_MODE": "PRODUCTION",
    "ORIGIN_URL": "https://ttx-operator-shell.sogellagepul.workers.dev"
  },
  // Revoked-refresh-token denylist (Phase 16). Production namespace —
  // staging uses dedicated namespaces in env.staging (see docs/RELEASE.md).
  "kv_namespaces": [
    { "binding": "AUTH_REVOCATION", "id": "9a7f43b04fcb439999dd60f3bd9d71a2" },
    { "binding": "WEBHOOK_EVENTS", "id": "c9b40c1ea3a74816aea05b42968c35d7" },
    { "binding": "SECURITY_EVENTS", "id": "99bb74eceaaf404ebee703bf3665dfce" },
    { "binding": "TTX_STATE", "id": "b86a60440f2a4b3db5f949eebf420e56" }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "GOVERNANCE", "class_name": "GovernanceDO" },
      { "name": "SESSION", "class_name": "SessionDO" },
      { "name": "MARKETPLACE", "class_name": "MarketplaceDO" },
      { "name": "LIVE_TTX_SESSIONS", "class_name": "LiveTtxSession" }
    ]
  },
  "migrations": [
    {
      "tag": "v1-operator-backbone",
      "new_sqlite_classes": ["GovernanceDO", "SessionDO", "MarketplaceDO"]
    },
    {
      "tag": "v36-live-ttx-sessions",
      "new_sqlite_classes": ["LiveTtxSession"]
    }
  ],
  "services": [
    { "binding": "HARNESS", "service": "msh-ops-os-harness" }
  ],
  "env": {
    "staging": {
      "name": "ttx-operator-shell-staging",
      "vars": {
        "ENGINE_API_URL": "https://msh-ops-os-harness.sogellagepul.workers.dev",
        "OPERATOR_ROLE": "operator",
        "OPERATOR_ACCESS_LEVEL": "internal",
        "DEPLOY_ENV": "staging",
        "APP_VERSION": "0.1.0",
        "BUILD_COMMIT_SHA": "unknown",
        "BUILD_TIMESTAMP": "",
        "SYSTEM_MODE": "OPERATOR_BETA",
        "ORIGIN_URL": "https://ttx-operator-shell-staging.sogellagepul.workers.dev"
      },
      "kv_namespaces": [
        // Replace each id with the output of the corresponding create command (run once before first staging deploy):
        //   wrangler kv namespace create AUTH_REVOCATION --env staging
        //   wrangler kv namespace create WEBHOOK_EVENTS --env staging
        //   wrangler kv namespace create SECURITY_EVENTS --env staging
        //   wrangler kv namespace create TTX_STATE --env staging
        { "binding": "AUTH_REVOCATION", "id": "a0000000000000000000000000000001", "preview_id": "a0000000000000000000000000000001" },
        { "binding": "WEBHOOK_EVENTS", "id": "a0000000000000000000000000000002", "preview_id": "a0000000000000000000000000000002" },
        { "binding": "SECURITY_EVENTS", "id": "a0000000000000000000000000000003", "preview_id": "a0000000000000000000000000000003" },
        { "binding": "TTX_STATE", "id": "a0000000000000000000000000000004", "preview_id": "a0000000000000000000000000000004" }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "GOVERNANCE", "class_name": "GovernanceDO" },
          { "name": "SESSION", "class_name": "SessionDO" },
          { "name": "MARKETPLACE", "class_name": "MarketplaceDO" },
          { "name": "LIVE_TTX_SESSIONS", "class_name": "LiveTtxSession" }
        ]
      },
      "migrations": [
        {
          "tag": "v1-operator-backbone",
          "new_sqlite_classes": ["GovernanceDO", "SessionDO", "MarketplaceDO"]
        },
        {
          "tag": "v36-live-ttx-sessions",
          "new_sqlite_classes": ["LiveTtxSession"]
        }
      ],
      "services": [
        { "binding": "HARNESS", "service": "msh-ops-os-harness" }
      ]
    }
  }
}
