{
  "name": "ttx-operator-shell",
  "version": "1.0.0",
  "description": "MSH OPS landing page and marketplace integration shell",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "worker:dev": "npx wrangler dev",
    "worker:deploy": "npx wrangler deploy",
    "smoke:worker:local": "npx wrangler dev --config wrangler.jsonc",
    "smoke:worker:remote": "npx wrangler dev --remote --config wrangler.remote-preview.jsonc --log-level debug",
    "smoke:worker:dry-run": "npx wrangler deploy --dry-run --config wrangler.jsonc",
    "build:public": "node scripts/build-unified-public.mjs",
    "pages:build": "npm run build:public",
    "pages:deploy": "npm run build:public && npx wrangler pages deploy public --project-name mshops-public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matrixsechub/ttx-operator-shell.git"
  },
  "keywords": [
    "mshops",
    "landing-page",
    "marketplace",
    "operator"
  ],
  "author": "MatrixSecHub",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/matrixsechub/ttx-operator-shell/issues"
  },
  "homepage": "https://github.com/matrixsechub/ttx-operator-shell#readme"
}
