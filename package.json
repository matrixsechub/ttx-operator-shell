{
  "name": "ttx-operator-shell",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "preview": "vite preview",
    "typecheck": "node scripts/typecheck.mjs",
    "worker:dev": "node scripts/build.mjs && wrangler dev",
    "deploy": "node scripts/build.mjs && wrangler deploy",
    "deploy:staging": "node scripts/deploy-staging.mjs",
    "verify:staging-config": "node scripts/verify-staging-config.mjs",
    "verify:deploy:handoff": "node scripts/verify-operator-deploy.mjs --handoff",
    "verify:deploy:beta": "node scripts/verify-operator-deploy.mjs --beta",
    "deploy:mshops-public": "node scripts/deploy-mshops-public.mjs",
    "deploy:mshops-operator": "node scripts/deploy-mshops-operator.mjs",
    "verify:step5": "node scripts/verify-step5-gate.mjs",
    "cf-typegen": "wrangler types",
    "test": "node --import tsx --test tests/apiAuth.test.ts tests/buildManifest.test.ts tests/stagingConfig.test.ts tests/statusRoute.test.ts tests/ttxSession.test.ts tests/verifyOperatorDeploy.test.ts"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
